---
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
}

const { title, description, keywords } = Astro.props;

const fullTitle = title ? `${title} | Fernando Berti` : "Fernando Berti";
const fullDescription =
  description ?? "Comparto mis ideas sobre programación y tecnología";
---

<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/fav.ico" sizes="any" />
    <link rel="icon" href="/fav.svg" type="image/svg+xml" />
    <link rel="manifest" href="/app.webmanifest" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={fullDescription} />
    <meta name="keywords" content={keywords} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:image" content="/og.jpg" />
    <meta name="theme-color" content="#09090b" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
  </head>

  <body>
    <slot />
    <style is:global>
      /* latin-ext */
      @font-face {
        font-family: "Martel";
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url(/PN_xRfK9oXHga0XdaMg_rz7b_sDa.woff2) format("woff2");
        unicode-range: U+0100-02AF, U+0304, U+0308, U+0329, U+1E00-1E9F,
          U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20CF, U+2113, U+2C60-2C7F,
          U+A720-A7FF;
      }
      /* latin */
      @font-face {
        font-family: "Martel";
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url(/PN_xRfK9oXHga0XdZsg_rz7b_g.woff2) format("woff2");
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6,
          U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC,
          U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      /* latin-ext */
      @font-face {
        font-family: "Martel";
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url(/PN_yRfK9oXHga0XV3e0qjBzW1PrTzkMi.woff2) format("woff2");
        unicode-range: U+0100-02AF, U+0304, U+0308, U+0329, U+1E00-1E9F,
          U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20CF, U+2113, U+2C60-2C7F,
          U+A720-A7FF;
      }
      /* latin */
      @font-face {
        font-family: "Martel";
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url(/PN_yRfK9oXHga0XV3e0qghzW1PrTzg.woff2) format("woff2");
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6,
          U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC,
          U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }

      :root {
        --background: 240 5% 96%;
        --foreground: 240 6% 10%;

        --muted: 210 40% 96.1%;
        --muted-foreground: 215.4 16.3% 46.9%;

        --popover: 0 0% 100%;
        --popover-foreground: 222.2 47.4% 11.2%;

        --border: 240 15% 80%;
        --input: 240 15% 80%;

        --card: 0 0% 100%;
        --card-foreground: 222.2 47.4% 11.2%;

        --primary: 222.2 47.4% 11.2%;
        --primary-foreground: 210 40% 98%;

        --secondary: 210 40% 96.1%;
        --secondary-foreground: 222.2 47.4% 11.2%;

        --accent: 210 40% 96.1%;
        --accent-foreground: 222.2 47.4% 11.2%;

        --destructive: 0 100% 50%;
        --destructive-foreground: 210 40% 98%;

        --ring: 215 20.2% 65.1%;

        --radius: 0.5rem;
      }

      .dark {
        --background: 240 6% 10%;
        --foreground: 240 5% 96%;

        --muted: 223 47% 11%;
        --muted-foreground: 215.4 16.3% 56.9%;

        --accent: 216 34% 17%;
        --accent-foreground: 210 40% 98%;

        --popover: 224 71% 4%;
        --popover-foreground: 215 20.2% 65.1%;

        --border: 240 10% 25%;
        --input: 240 10% 25%;

        --card: 224 71% 4%;
        --card-foreground: 213 31% 91%;

        --primary: 210 40% 98%;
        --primary-foreground: 222.2 47.4% 1.2%;

        --secondary: 222.2 47.4% 11.2%;
        --secondary-foreground: 210 40% 98%;

        --destructive: 0 63% 31%;
        --destructive-foreground: 210 40% 98%;

        --ring: 216 34% 17%;

        --radius: 0.5rem;
      }

      * {
        @apply border-border;
      }
      body {
        @apply bg-background text-foreground;
        font-feature-settings:
          "rlig" 1,
          "calt" 1;
        font-family: "Martel", serif;
      }

      ::selection {
        background-color: #e11d48;
        color: #fefefe;
      }

      [data-highlighted-line] {
        background: rgba(200, 200, 255, 0.1);
        @apply border-b border-transparent;
      }

      [data-rehype-pretty-code-title] {
        @apply rounded-t-lg bg-zinc-800 px-3 py-2 font-mono text-sm font-semibold text-zinc-200;
      }

      figcaption + pre {
        @apply !rounded-t-none;
      }

      a {
        @apply cursor-pointer font-bold !no-underline transition-all hover:text-rose-600 dark:hover:text-rose-400;
        overflow-wrap: break-word;
        word-wrap: break-word;
        hyphens: auto;
      }
    </style>
  </body>
</html>
